{
  "name": "finanzas-personales-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "api": "node server/index.mjs",
    "dev": "vite",
    "dev:mobile": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:e2e": "node scripts/prepare-e2e.mjs && playwright test",
    "test:unit": "vitest run src",
    "test:e2e:headed": "node scripts/prepare-e2e.mjs && playwright test --headed",
    "test:imports": "node scripts/validate-synthetic-imports.mjs",
    "test:imports:real": "node scripts/validate-real-imports.mjs --allow-real-docs",
    "test:knowledge": "node scripts/validate-knowledge-seed.mjs",
    "analyze:documents": "node scripts/analyze-document-quality.mjs",
    "benchmark:documents": "node scripts/benchmark-document-libraries.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^1.21.0",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
  }
}
